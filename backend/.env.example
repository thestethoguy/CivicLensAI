# CivicLens AI – Backend Environment Configuration
# Copy this file to .env and fill in the values before starting the server.

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=CivicLens AI
APP_VERSION=1.0.0
DEBUG=true

# ── MongoDB ───────────────────────────────────────────────────────────────────
# For local MongoDB:
MONGODB_URI=mongodb://localhost:27017
# For MongoDB Atlas, replace the URI above with your connection string:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=civiclens

# ── Google AI Studio ──────────────────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=YOUR_GOOGLE_AI_STUDIO_API_KEY_HERE

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
